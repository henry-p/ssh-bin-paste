#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/ssh-bin-paste"
CONFIG_FILE="$CONFIG_DIR/config.sh"
CACHE_DIR="$HOME/.cache/ssh-bin-paste"
STATE_DIR="$CACHE_DIR"
ASSET_DIR="${SSH_BIN_PASTE_ASSET_DIR:-$HOME/.local/share/ssh-bin-paste}"
REMOTE_HELPER_ASSET="$ASSET_DIR/ssh-bin-paste-remote.sh"
CLIPBOARD_HELPER="$ASSET_DIR/clipboard-capture.swift"
PASTE_UP="$ASSET_DIR/paste-up.swift"
LOCAL_UP_PID="$STATE_DIR/local-up.pid"
LOCAL_UP_LOG="$STATE_DIR/local-up.log"
PAIRING_FILE="$STATE_DIR/current-pairing"

HOST="example-vps"
SSH_COMMAND=""
AGENT_CODEX_COMMAND="codex"
AGENT_CLAUDE_COMMAND="claude"
TMUX_SESSION="agent"
REMOTE_CACHE_DIR="~/.cache/ssh-bin-paste/files"
REMOTE_HELPER_PATH="~/.local/bin/ssh-bin-paste-remote"
CLEANUP_ENABLED="1"
CLEANUP_MAX_AGE_SECONDS="86400"
CLEANUP_INTERVAL_SECONDS="300"
HIJACK_PASTE="0"

usage() {
  cat <<'USAGE'
usage: ssh-bin-paste <command> [args]

commands:
  config             configure SSH, install the remote helper, and start the paste shortcut
  up                 run the paste shortcut and auto-pair with remote attach
  version            print version
USAGE
}

shell_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\''/g")"
}

write_config_value() {
  local key="$1" value="$2"
  printf '%s=' "$key"
  shell_quote "$value"
  printf '\n'
}

save_config() {
  mkdir -p "$CONFIG_DIR"
  {
    printf '# ssh-bin-paste config\n'
    write_config_value HOST "$HOST"
    write_config_value SSH_COMMAND "$SSH_COMMAND"
    write_config_value AGENT_CODEX_COMMAND "$AGENT_CODEX_COMMAND"
    write_config_value AGENT_CLAUDE_COMMAND "$AGENT_CLAUDE_COMMAND"
    write_config_value TMUX_SESSION "$TMUX_SESSION"
    write_config_value REMOTE_CACHE_DIR "$REMOTE_CACHE_DIR"
    write_config_value REMOTE_HELPER_PATH "$REMOTE_HELPER_PATH"
    write_config_value CLEANUP_ENABLED "$CLEANUP_ENABLED"
    write_config_value CLEANUP_MAX_AGE_SECONDS "$CLEANUP_MAX_AGE_SECONDS"
    write_config_value CLEANUP_INTERVAL_SECONDS "$CLEANUP_INTERVAL_SECONDS"
    write_config_value HIJACK_PASTE "$HIJACK_PASTE"
  } > "$CONFIG_FILE"
}

load_config() {
  if [ -f "$CONFIG_FILE" ]; then
    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
  fi
}

prompt() {
  local label="$1" default="$2" answer
  while true; do
    printf '%s [%s]: ' "$label" "$default" >/dev/tty
    IFS= read -r answer </dev/tty
    answer="${answer:-$default}"
    if [ -n "$answer" ]; then
      printf '%s\n' "$answer"
      return 0
    fi
    printf 'Please enter a value.\n' >/dev/tty
  done
}

prompt_yes_no() {
  local label="$1" default="$2" answer prompt_label
  if [ "$default" = "1" ]; then prompt_label="Y/n"; else prompt_label="y/N"; fi
  while true; do
    printf '%s [%s]: ' "$label" "$prompt_label" >/dev/tty
    IFS= read -r answer </dev/tty
    case "${answer:-$default}" in
      1|y|Y|yes|YES) return 0 ;;
      0|n|N|no|NO) return 1 ;;
      *) printf 'Please answer yes or no.\n' >/dev/tty ;;
    esac
  done
}

validate_host_alias() {
  case "$1" in ssh\ *) return 1 ;; esac
  [ "$(printf '%s' "$1" | wc -w | tr -d ' ')" = "1" ]
}

validate_ssh_command() {
  case "$1" in ssh\ *|*/ssh\ *) return 0 ;; *) return 1 ;; esac
}

run_config_wizard() {
  load_config
  mkdir -p "$CONFIG_DIR"
  printf 'ssh-bin-paste config\n\n' >/dev/tty
  printf 'Remote target:\n  1. SSH config host alias\n  2. Full SSH command\n' >/dev/tty
  local default_mode="1" mode
  [ -n "$SSH_COMMAND" ] && default_mode="2"
  while true; do
    mode="$(prompt 'Choose' "$default_mode")"
    case "$mode" in 1|2) break ;; *) printf 'Choose 1 or 2.\n' >/dev/tty ;; esac
  done
  if [ "$mode" = "1" ]; then
    while true; do
      HOST="$(prompt 'SSH host alias' "$HOST")"
      if validate_host_alias "$HOST"; then break; fi
      printf 'Enter a single SSH host alias, not a full ssh command.\n' >/dev/tty
    done
    SSH_COMMAND=""
  else
    local default_ssh="${SSH_COMMAND:-ssh -i ~/.ssh/example_ed25519 user@203.0.113.10}"
    while true; do
      SSH_COMMAND="$(prompt 'Full SSH command' "$default_ssh")"
      if validate_ssh_command "$SSH_COMMAND"; then break; fi
      printf 'SSH command must start with ssh.\n' >/dev/tty
    done
  fi

  AGENT_CODEX_COMMAND="$(prompt 'Codex command' "$AGENT_CODEX_COMMAND")"
  AGENT_CLAUDE_COMMAND="$(prompt 'Claude Code command' "$AGENT_CLAUDE_COMMAND")"
  TMUX_SESSION="$(prompt 'Managed tmux session' "$TMUX_SESSION")"
  REMOTE_CACHE_DIR="$(prompt 'Remote file cache dir' "$REMOTE_CACHE_DIR")"
  REMOTE_HELPER_PATH="$(prompt 'Remote helper path' "$REMOTE_HELPER_PATH")"
  if prompt_yes_no 'Start remote cache cleanup worker' "$CLEANUP_ENABLED"; then CLEANUP_ENABLED="1"; else CLEANUP_ENABLED="0"; fi
  CLEANUP_MAX_AGE_SECONDS="$(prompt 'Cleanup max age seconds' "$CLEANUP_MAX_AGE_SECONDS")"
  CLEANUP_INTERVAL_SECONDS="$(prompt 'Cleanup interval seconds' "$CLEANUP_INTERVAL_SECONDS")"
  save_config
  printf '\nwrote %s\n' "$CONFIG_FILE" >/dev/tty
}

save_pairing() {
  local attach_id="$1" tmux_session="$2" created_at="$3"
  mkdir -p "$STATE_DIR"
  {
    printf '# ssh-bin-paste current pairing\n'
    write_config_value PAIR_HOST "$HOST"
    write_config_value PAIR_SSH_COMMAND "$SSH_COMMAND"
    write_config_value PAIR_ATTACH_ID "$attach_id"
    write_config_value PAIR_TMUX_SESSION "$tmux_session"
    write_config_value PAIR_CREATED_AT "$created_at"
  } > "$PAIRING_FILE"
}

load_pairing_target() {
  [ -f "$PAIRING_FILE" ] || return 1
  # shellcheck disable=SC1090
  . "$PAIRING_FILE"
  [ -n "${PAIR_ATTACH_ID:-}" ] || return 1
  HOST="${PAIR_HOST:-$HOST}"
  SSH_COMMAND="${PAIR_SSH_COMMAND:-}"
  return 0
}

parse_remote_opts() {
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --host) HOST="$2"; shift 2 ;;
      --ssh) SSH_COMMAND="$2"; shift 2 ;;
      --hijack-paste) HIJACK_PASTE="1"; shift ;;
      --*) printf 'unknown option: %s\n' "$1" >&2; exit 2 ;;
      *) EXTRA_ARG="$1"; shift ;;
    esac
  done
}

ssh_array_eval() {
  # User-provided SSH command; this intentionally uses shell parsing so quoted -o values work.
  eval "SSH_PARTS=($SSH_COMMAND)"
}

run_ssh() {
  local remote_command="$1"
  if [ -n "$SSH_COMMAND" ]; then
    local -a SSH_PARTS
    ssh_array_eval
    "${SSH_PARTS[@]}" "$remote_command"
  else
    ssh "$HOST" "$remote_command"
  fi
}

run_ssh_stdin() {
  local remote_command="$1" input_file="$2"
  if [ -n "$SSH_COMMAND" ]; then
    local -a SSH_PARTS
    ssh_array_eval
    "${SSH_PARTS[@]}" "$remote_command" < "$input_file"
  else
    ssh "$HOST" "$remote_command" < "$input_file"
  fi
}

remote_path_expr() {
  case "$1" in
    '~') printf '"$HOME"' ;;
    '~/'*) printf '"$HOME/%s"' "$(printf '%s' "${1#\~/}" | sed 's/["`$\\]/\\&/g')" ;;
    *) shell_quote "$1" ;;
  esac
}

remote_helper_command() {
  local cmd
  cmd="$(remote_path_expr "$REMOTE_HELPER_PATH")"
  shift 0
  for arg in "$@"; do
    cmd="$cmd $(shell_quote "$arg")"
  done
  printf '%s\n' "$cmd"
}

run_remote_helper() {
  local remote_cmd
  remote_cmd="$(remote_helper_command "$@")"
  run_ssh "$remote_cmd"
}

run_remote_helper_stdin() {
  local input_file="$1" remote_cmd
  shift
  remote_cmd="$(remote_helper_command "$@")"
  run_ssh_stdin "$remote_cmd" "$input_file"
}

first_word() {
  set -- $1
  printf '%s\n' "${1:-}"
}

check_line() {
  local ok="$1" label="$2" detail="$3"
  if [ "$ok" = "1" ]; then printf 'ok   %s: %s\n' "$label" "$detail"; else printf 'fail %s: %s\n' "$label" "$detail"; return 1; fi
}

check_requirements() {
  load_config
  parse_remote_opts "$@"
  local ok=1 out codex_bin claude_bin codex_ok=0 claude_ok=0
  codex_bin="$(first_word "$AGENT_CODEX_COMMAND")"
  claude_bin="$(first_word "$AGENT_CLAUDE_COMMAND")"
  check_line 1 'local platform' "$(uname -s)" || ok=0
  command -v ssh >/dev/null 2>&1 && check_line 1 'local ssh' "$(command -v ssh)" || { check_line 0 'local ssh' 'not found'; ok=0; }
  command -v swift >/dev/null 2>&1 && check_line 1 'local swift' "$(command -v swift)" || { check_line 0 'local swift' 'not found'; ok=0; }
  if out="$(run_ssh 'printf ok' 2>&1)" && [ "$out" = "ok" ]; then check_line 1 'ssh access' ok; else check_line 0 'ssh access' "$out"; ok=0; fi
  if out="$(run_ssh 'command -v tmux 2>/dev/null || true' 2>&1)" && [ -n "$out" ]; then check_line 1 'remote tmux' "$out"; else check_line 0 'remote tmux' 'not found'; ok=0; fi
  if [ -n "$codex_bin" ] && out="$(run_ssh "command -v $(shell_quote "$codex_bin") 2>/dev/null || true" 2>&1)" && [ -n "$out" ]; then check_line 1 'remote Codex' "$out"; codex_ok=1; else printf 'info remote Codex: %s not found\n' "${codex_bin:-codex}"; fi
  if [ -n "$claude_bin" ] && out="$(run_ssh "command -v $(shell_quote "$claude_bin") 2>/dev/null || true" 2>&1)" && [ -n "$out" ]; then check_line 1 'remote Claude Code' "$out"; claude_ok=1; else printf 'info remote Claude Code: %s not found\n' "${claude_bin:-claude}"; fi
  if [ "$codex_ok" = "0" ] && [ "$claude_ok" = "0" ]; then check_line 0 'remote agent' 'neither Codex nor Claude Code was found'; ok=0; fi
  local cache_expr
  cache_expr="$(remote_path_expr "$REMOTE_CACHE_DIR")"
  if out="$(run_ssh "mkdir -p $cache_expr && test -w $cache_expr && printf ok" 2>&1)" && [ "$out" = "ok" ]; then check_line 1 'remote cache dir' "$REMOTE_CACHE_DIR"; else check_line 0 'remote cache dir' "$out"; ok=0; fi
  [ "$ok" = "1" ]
}

remote_dirname() {
  local path="${1%/}"
  case "$path" in */*) printf '%s\n' "${path%/*}" ;; *) printf '.\n' ;; esac
}

remote_basename() {
  local path="${1%/}"
  printf '%s\n' "${path##*/}"
}

path_profile_block() {
  local dir="$1"
  local assignment
  case "$dir" in
    '~') assignment='SBP_BIN_DIR="$HOME"' ;;
    '~/'*) assignment="SBP_BIN_DIR=\"\$HOME/${dir#\~/}\"" ;;
    *) assignment="SBP_BIN_DIR=$(shell_quote "$dir")" ;;
  esac
  cat <<EOF2

# ssh-bin-paste PATH
$assignment
case \":\$PATH:\" in
  *\":\$SBP_BIN_DIR:\"*) ;;
  *) export PATH=\"\$SBP_BIN_DIR:\$PATH\" ;;
esac
EOF2
}

install_remote_helper() {
  load_config
  parse_remote_opts "$@"
  [ -f "$REMOTE_HELPER_ASSET" ] || { printf 'missing asset: %s\n' "$REMOTE_HELPER_ASSET" >&2; exit 1; }
  local dir wrapper_path helper_name install_cmd verify wrapper tmp_wrapper
  dir="$(remote_dirname "$REMOTE_HELPER_PATH")"
  helper_name="$(remote_basename "$REMOTE_HELPER_PATH")"
  wrapper_path="${dir%/}/ssh-bin-paste"
  run_ssh "mkdir -p $(remote_path_expr "$dir")"
  install_cmd="cat > $(remote_path_expr "$REMOTE_HELPER_PATH") && chmod 0755 $(remote_path_expr "$REMOTE_HELPER_PATH")"
  run_ssh_stdin "$install_cmd" "$REMOTE_HELPER_ASSET"
  verify="$(run_ssh "$(remote_path_expr "$REMOTE_HELPER_PATH") version")"
  tmp_wrapper="$(mktemp)"
  cat > "$tmp_wrapper" <<EOF2
#!/usr/bin/env bash
set -euo pipefail
DIR="\$(CDPATH= cd -- "\$(dirname -- "\$0")" && pwd)"
exec "\$DIR/$helper_name" "\$@"
EOF2
  run_ssh_stdin "cat > $(remote_path_expr "$wrapper_path") && chmod 0755 $(remote_path_expr "$wrapper_path")" "$tmp_wrapper"
  rm -f "$tmp_wrapper"
  local profile_block
  profile_block="$(path_profile_block "$dir")"
  run_ssh "for profile in \"\$HOME/.profile\" \"\$HOME/.zshrc\" \"\$HOME/.bashrc\"; do touch \"\$profile\"; grep -q 'ssh-bin-paste PATH' \"\$profile\" || cat >> \"\$profile\" <<'SBP_PATH_EOF'
$profile_block
SBP_PATH_EOF
done"
  printf 'installed %s and %s on %s (%s)\n' "$REMOTE_HELPER_PATH" "$wrapper_path" "${SSH_COMMAND:-ssh $HOST}" "$verify"
  if [ "$CLEANUP_ENABLED" = "1" ]; then
    run_remote_helper cleanup-start "$REMOTE_CACHE_DIR" "$CLEANUP_MAX_AGE_SECONDS" "$CLEANUP_INTERVAL_SECONDS" | sed 's/^/cleanup worker /'
  fi
}

pair_watch_loop() {
  printf 'Waiting for remote attach on %s. In SSH, run: ssh-bin-paste attach\n' "${SSH_COMMAND:-$HOST}"

  local request attach_id tmux_session created_at
  while true; do
    request="$(run_remote_helper pairing-next 2>/dev/null || true)"
    if [ -n "$request" ]; then
      attach_id="$(printf '%s\n' "$request" | sed -n "s/^attach_id='\(.*\)'$/\1/p" | sed "s/'\\\\''/'/g")"
      tmux_session="$(printf '%s\n' "$request" | sed -n "s/^tmux_session='\(.*\)'$/\1/p" | sed "s/'\\\\''/'/g")"
      created_at="$(printf '%s\n' "$request" | sed -n "s/^created_at='\(.*\)'$/\1/p")"
      if [ -n "$attach_id" ] && [ -n "$tmux_session" ]; then
        save_pairing "$attach_id" "$tmux_session" "${created_at:-$(date +%s)}"
        run_remote_helper pairing-consume "$attach_id" >/dev/null 2>&1 || true
        printf 'Paired %s -> %s.\n' "${SSH_COMMAND:-$HOST}" "$tmux_session"
      fi
    fi
    sleep 2
  done
}

resolve_target_pane() {
  if [ -n "${PAIR_ATTACH_ID:-}" ]; then
    run_remote_helper resolve-attach "$PAIR_ATTACH_ID"
    return
  fi
  return 1
}

extension_for_mime() {
  case "$1" in
    image/png) printf 'png' ;;
    image/jpeg) printf 'jpg' ;;
    image/webp) printf 'webp' ;;
    image/gif) printf 'gif' ;;
    *) printf 'bin' ;;
  esac
}

json_field() {
  local field="$1"
  sed -n "s/.*\"$field\":\"\([^\"]*\)\".*/\1/p" | sed 's#\\/#/#g; s#\\"#"#g; s#\\\\#\\#g'
}

internal_paste() {
  load_config
  parse_remote_opts "$@"
  load_pairing_target || {
    printf 'No paired remote session. Keep ssh-bin-paste up running on your Mac, then run ssh-bin-paste attach on the VPS.\n' >&2
    exit 1
  }
  [ -f "$CLIPBOARD_HELPER" ] || { printf 'missing asset: %s\n' "$CLIPBOARD_HELPER" >&2; exit 1; }
  local output_path capture local_path mime ext cache remote_path target now uuid
  output_path="$(mktemp -t ssh-bin-paste.XXXXXX).png"
  capture="$(swift "$CLIPBOARD_HELPER" --output "$output_path")"
  local_path="$(printf '%s\n' "$capture" | json_field path)"
  mime="$(printf '%s\n' "$capture" | json_field mimeType)"
  ext="$(extension_for_mime "$mime")"
  cache="$(run_remote_helper ensure-cache "$REMOTE_CACHE_DIR")"
  now="$(date +%s)"
  uuid="$(uuidgen | tr '[:upper:]' '[:lower:]')"
  remote_path="${cache%/}/ssh-bin-paste-$now-$uuid.$ext"
  run_ssh_stdin "cat > $(shell_quote "$remote_path") && chmod 0600 $(shell_quote "$remote_path")" "$local_path"
  target="$(resolve_target_pane)"
  [ -n "$target" ] || { printf 'Paired remote session is stale. Keep ssh-bin-paste up running, then run ssh-bin-paste attach again.\n' >&2; exit 1; }
  printf '%s' "$remote_path" | run_remote_helper_stdin /dev/stdin inject "$target"
  printf 'pasted %s into %s\n' "$remote_path" "$target"
}

cmd_up() {
  load_config
  parse_remote_opts "$@"
  [ -f "$PASTE_UP" ] || { printf 'missing asset: %s\n' "$PASTE_UP" >&2; exit 1; }
  local args=("$PASTE_UP" --command "$(command -v ssh-bin-paste || printf '%s' "$0")")
  if [ -n "$SSH_COMMAND" ]; then args+=(--ssh "$SSH_COMMAND"); else args+=(--host "$HOST"); fi
  [ "$HIJACK_PASTE" = "1" ] && args+=(--hijack-paste)
  pair_watch_loop &
  local watcher_pid="$!"
  trap 'kill "$watcher_pid" 2>/dev/null || true' EXIT INT TERM
  swift "${args[@]}"
}

up_pid_alive() {
  [ -f "$LOCAL_UP_PID" ] || return 1
  local pid
  pid="$(cat "$LOCAL_UP_PID" 2>/dev/null || true)"
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

start_up_background() {
  load_config
  mkdir -p "$STATE_DIR"
  if up_pid_alive; then
    printf 'paste shortcut already running pid=%s\n' "$(cat "$LOCAL_UP_PID")"
    return 0
  fi
  nohup "$(command -v ssh-bin-paste || printf '%s' "$0")" up >>"$LOCAL_UP_LOG" 2>&1 &
  printf '%s\n' "$!" > "$LOCAL_UP_PID"
  sleep 1
  if up_pid_alive; then
    printf 'paste shortcut running pid=%s\n' "$(cat "$LOCAL_UP_PID")"
  else
    cat "$LOCAL_UP_LOG" >&2
    return 1
  fi
}

cmd_config() {
  run_config_wizard
  check_requirements
  install_remote_helper
  start_up_background || true
  printf '\nconfig complete\n'
}

main() {
  local cmd="${1:-}"
  [ $# -gt 0 ] && shift || true
  case "$cmd" in
    config) cmd_config "$@" ;;
    __paste) internal_paste "$@" ;;
    up) cmd_up "$@" ;;
    version|--version|-V) printf '%s\n' "$VERSION" ;;
    help|--help|-h|'') usage ;;
    *) printf 'unknown command: %s\n\n' "$cmd" >&2; usage >&2; exit 2 ;;
  esac
}

main "$@"
